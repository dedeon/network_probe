# ============================================
# .gitignore — 小D网络拨测工具 NetProbe
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
*.egg
*.whl
.eggs/
*.so

# ---------- PyInstaller 构建产物 ----------
dist/
build/
*.spec.bak
_build_python/
_upx/

# ---------- 嵌入式 Python & 压缩包 ----------
python-*.zip
python-*.embed*/

# ---------- 运行时数据 ----------
network_probe/data/

# ---------- 日志 ----------
*.log
*.log.*

# ---------- 数据库 ----------
*.db
*.sqlite3

# ---------- IDE / 编辑器 ----------
.codebuddy/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- 虚拟环境 ----------
.venv/
venv/
env/
.env

# ---------- 其他工作区文件（非本项目） ----------
docs/
public/
server.js
server.py
server.log
package.json
